    border-color: var(--border-accent);
  }

  .cta-icon {
    width: 24px;
    height: 24px;
    margin-bottom: 4px;
  }

  .cta-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .cta-sub {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .cta-scriptohub:hover {
    box-shadow: 0 12px 32px var(--shadow-accent-soft);
  }

  .cta-scriptohub .cta-icon {
    color: var(--accent-bright);
  }

  .cta-studio:hover {
    box-shadow: 0 12px 32px var(--shadow-cyan-soft);
  }

  .cta-studio .cta-icon {
    color: var(--cyan-bright);
  }

  .cta-github:hover {
    box-shadow: 0 12px 32px var(--shadow-github-soft);
