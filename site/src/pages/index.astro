    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: 0.08em;
    line-height: 1.3;
  }

  .rp2350-line2 {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: 0.06em;
    opacity: 0.85;
    line-height: 1.2;
  }

  /* Hero HUD Dashboard */
  .hero-hud {
    margin-top: 32px;
    max-width: 820px;
    margin-left: auto;
    margin-right: auto;
    aspect-ratio: 16 / 9;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 8px 40px var(--shadow-accent-soft),
      0 0 60px rgba(0, 200, 83, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hero-hud:hover {
    transform: translateY(-4px);
    box-shadow:
      0 16px 60px var(--shadow-accent-mid),
      0 0 80px rgba(0, 200, 83, 0.12);
