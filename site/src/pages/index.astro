  .pwa-tagline {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--text-primary);
    display: block;
    margin-bottom: 12px;
  }

  .pwa-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 460px;
    margin: 0 auto 20px;
    line-height: 1.6;
  }

  .pwa-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    border-radius: 12px;
    background: var(--accent-bright);
    color: var(--bg-deep);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 4px 20px var(--shadow-accent-mid);
  }

  .pwa-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px var(--shadow-accent-strong);
  }

  .pwa-btn svg {
    width: 18px;
    height: 18px;
  }

  .pwa-meta {
    display: block;
    margin-top: 12px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .pwa-screenshot {
    margin: 20px auto;
    max-width: 680px;
  }

  .pwa-screenshot img {
    width: 100%;
    border-radius: 10px;
    box-shadow:
      0 6px 28px var(--shadow-accent-soft),
      0 0 40px rgba(0, 200, 83, 0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .pwa-screenshot img:hover {
    transform: translateY(-3px);
    box-shadow:
      0 12px 40px var(--shadow-accent-mid),
      0 0 50px rgba(0, 200, 83, 0.1);
  }

  /* CTA Grid */
  .cta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    margin-bottom: 56px;
  }

  .cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 24px 16px;
    border-radius: 16px;
    background: var(--surface-card);
    border: 1px solid var(--border-subtle);
    backdrop-filter: blur(10px);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.25s ease;
    position: relative;
  }

  .cta:hover {
