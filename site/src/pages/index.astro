  }

  .cta-discord {
    color: #5865F2;
  }

  .cta-coming-soon {
    opacity: 0.6;
    cursor: default;
    pointer-events: none;
  }

  .coming-soon-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 8px;
    border-radius: 6px;
    background: rgba(88, 101, 242, 0.15);
    color: #5865F2;
  }

  /* Footer */
  .footer {
    text-align: center;
    padding: 32px 0;
    margin-top: auto;
    font-size: 0.85rem;
    color: var(--text-muted);
    border-top: 1px solid var(--border-subtle);
  }

  .footer-nav {
    margin-bottom: 12px;
  }

  .footer-nav a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-nav a:hover {
    color: var(--accent-bright);
  }

  .footer-separator {
    margin: 0 8px;
    color: var(--text-muted);
  }

  .footer a {
    color: var(--accent-bright);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .footer a:hover {
    opacity: 0.8;
  }

  .disclaimer {
    margin-top: 8px;
    font-size: 0.75rem;
    opacity: 0.6;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .container {
      padding: 40px 16px 32px;
    }

    .hero {
      margin-bottom: 48px;
    }

    .features, .comparison, .pwa-section {
      margin-bottom: 48px;
    }

    .hero-ctas {
      flex-direction: column;
      align-items: center;
    }

    .hero-btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }

    .comparison-table {
      font-size: 0.72rem;
    }

    .comparison-table th,
    .comparison-table td {
      padding: 8px 10px;
    }

    .approach-tag {
      font-size: 0.65rem;
      padding: 2px 7px;
    }

    .cta-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero-hud {
      aspect-ratio: 4 / 3;
    }

    .rp2350-banner {
      top: 14px;
      left: -50px;
      width: 200px;
      font-size: 0.5rem;
      padding: 4px 0;
    }
  }

  /* RP2350 Diagonal Banner */
  .rp2350-banner {
    position: fixed;
    top: 22px;
    left: -50px;
    width: 200px;
    z-index: 1000;
    background: linear-gradient(135deg, var(--accent-bright), var(--cyan-bright));
    color: var(--bg-deep);
    text-align: center;
    padding: 6px 0;
    font-family: var(--font-body);
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    transform: rotate(-45deg);
    transform-origin: center;
    box-shadow: 0 3px 12px var(--shadow-accent-mid);
    pointer-events: auto;
    overflow: visible;
  }

  .rp2350-line1 {
    display: block;
